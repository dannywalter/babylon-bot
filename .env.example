BABYLON_AUTH_MODE=auto

# Choose one auth path:
# 1. API key
BABYLON_API_KEY=

# 2. Existing session or bearer token
BABYLON_SESSION_TOKEN=
BABYLON_BEARER_TOKEN=

# 3. Agent auth for autonomous systems
BABYLON_AGENT_ID=
BABYLON_CRON_SECRET=
BABYLON_AGENT_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

EXECUTION_MODE=dry-run
RUN_ONCE=true
POLL_INTERVAL_MS=60000

MARKET_LIMIT=50
TRADE_AMOUNT=10
MIN_EDGE=0.15
MIN_VOLUME=0
MAX_MARKETS=5
MAX_OPEN_MARKETS=5
MAX_TOTAL_EXPOSURE=100
ONE_POSITION_PER_MARKET=true
MARKET_ALLOWLIST=

ALLOW_MUTATING_TOOLS=false
BABYLON_ALLOWED_TOOLS=
BABYLON_BLOCKED_TOOLS=
