BABYLON_AUTH_MODE=auto

# Choose one auth path:
# 1. API key
BABYLON_API_KEY=

# 2. Existing session or bearer token
BABYLON_SESSION_TOKEN=
BABYLON_BEARER_TOKEN=

# 3. Agent auth for autonomous systems
BABYLON_AGENT_ID=
BABYLON_CRON_SECRET=
BABYLON_AGENT_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

EXECUTION_MODE=dry-run
RUN_ONCE=true
POLL_INTERVAL_MS=60000

MARKET_LIMIT=50
TRADE_AMOUNT=10
MIN_EDGE=0.15
MIN_VOLUME=0
MAX_MARKETS=5
MAX_OPEN_MARKETS=5
MAX_TOTAL_EXPOSURE=100
ONE_POSITION_PER_MARKET=true
MARKET_ALLOWLIST=

ALLOW_MUTATING_TOOLS=false
BABYLON_ALLOWED_TOOLS=
BABYLON_BLOCKED_TOOLS=

# ── agent-server.js / register-agent.js ──────────────────────────────────────
# Public URL where agent-server.js is deployed (e.g. Railway)
AGENT_ENDPOINT=https://web-production-60c99.up.railway.app/

# ── position-flipper.js ──────────────────────────────────────────────────────
# Your Babylon DID (did:privy:... identifier)
BABYLON_USER_ID=

# Comma-separated list of tickers to monitor
TICKERS=OPENAGI,TSLAI,METAI

# Per-ticker flip thresholds (price above → short, price below → long)
OPENAGI_FLIP_TO_SHORT_ABOVE=1750
OPENAGI_FLIP_TO_LONG_BELOW=200
TSLAI_FLIP_TO_SHORT_ABOVE=970
TSLAI_FLIP_TO_LONG_BELOW=120
METAI_FLIP_TO_SHORT_ABOVE=1700
METAI_FLIP_TO_LONG_BELOW=350

# Discord webhook for flip notifications (optional)
DISCORD_WEBHOOK_URL=

# Director agent: mirrors flips on a separate agent's capped balance (optional)
DIRECTOR_AGENT_ID=
DIRECTOR_TRADE_SIZE=

# Set to true to simulate without placing real trades
DRY_RUN=false

# ── yolobot.js (manual strategy script; not part of the live workflow) ───────
# Agent ID for YOLObot
YOLOBOT_AGENT_ID=

# Comma-separated tickers YOLObot should trade
YOLO_TICKERS=METAI

# Fixed dollar size per YOLObot trade
YOLO_TRADE_SIZE=1000

# Stop-loss and take-profit thresholds (percentages)
YOLO_STOP_LOSS_PCT=10
YOLO_TAKE_PROFIT_PCT=20

# Minimum 24-hour price move (%) required to open a new position
YOLO_MIN_24H_MOVE=5
